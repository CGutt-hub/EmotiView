
// Reference generic config
includeConfig '../../../AnalysisToolbox/gitatbx/bin/nextflow.config'

// Process-specific resource overrides (EV pilot uses ICA and raw XDF extraction)
process {
    withName: 'ic_analyzer' {
        memory = { 8.GB * task.attempt }
        cpus = 4
        maxRetries = 3
    }
    withName: 'extracting_processor' {
        memory = { 6.GB * task.attempt }
        maxRetries = 3
    }
}

// Git commit author configuration
params.git_user_name     = 'EmotiView Pipeline'
params.git_user_email    = 'emotiview-pipeline@automated.local'

// EmotiView Nextflow Pipeline Parameters

// Input/Output
params.input_dir           = '../../../../rawData'
params.output_dir          = '../../EV_results/pilot'
params.procedure_html_dir  = '.'
params.participant_pattern = 'EV_*'
params.project_name        = 'EV'

// Redirect Nextflow trace to EV_results/pilot/ so it lives alongside the results data.
trace {
    enabled = true
    file    = "../../EV_results/pilot/.bin/pipeline_trace.txt"
}

// Python environment
params.python_exe          = '/home/gutt/EV_venv/bin/python3'
params.venv_path           = '/home/gutt/EV_venv'
params.txt_encoding        = 'utf-16'

// Script paths
params.txt_reader_script                = '../../../AnalysisToolbox/gitatbx/modules/readers/txt_reader.py'
params.xdf_reader_script                = '../../../AnalysisToolbox/gitatbx/modules/readers/xdf_reader.py'
params.file_finder_script               = '../../../AnalysisToolbox/gitatbx/modules/utils/file_finder.py'
params.extracting_processor_script      = '../../../AnalysisToolbox/gitatbx/modules/processors/extracting_processor.py'
params.peak_detection_processor_script  = '../../../AnalysisToolbox/gitatbx/modules/processors/peak_detection_processor.py'
params.tree_processor_script            = '../../../AnalysisToolbox/gitatbx/modules/processors/tree_processor.py'
params.events_processor_script          = '../../../AnalysisToolbox/gitatbx/modules/processors/events_processor.py'
params.filtering_processor_script       = '../../../AnalysisToolbox/gitatbx/modules/processors/filtering_processor.py'
params.rejection_processor_script       = '../../../AnalysisToolbox/gitatbx/modules/processors/rejection_processor.py'
params.row_filter_processor_script      = '../../../AnalysisToolbox/gitatbx/modules/processors/row_filter_processor.py'
params.phase_analyzer_script            = '../../../AnalysisToolbox/gitatbx/modules/analyzers/phase_analyzer.py'
params.epoching_processor_script        = '../../../AnalysisToolbox/gitatbx/modules/processors/epoching_processor.py'
params.concatenating_processor_script   = '../../../AnalysisToolbox/gitatbx/modules/processors/concatenating_processor.py'
params.ols_processor_script             = '../../../AnalysisToolbox/gitatbx/modules/processors/ols_processor.py'
params.contrast_processor_script        = '../../../AnalysisToolbox/gitatbx/modules/processors/contrast_processor.py'
params.condition_profile_processor_script = '../../../AnalysisToolbox/gitatbx/modules/processors/condition_profile_processor.py'
params.correl_analyzer_script             = '../../../AnalysisToolbox/gitatbx/modules/analyzers/correl_analyzer.py'
params.anova_analyzer_script              = '../../../AnalysisToolbox/gitatbx/modules/analyzers/anova_analyzer.py'
params.multimodal_epoch_processor_script  = '../../../AnalysisToolbox/gitatbx/modules/processors/multimodal_epoch_processor.py'
params.l2_analyses                        = false
params.relative_analyzer_script         = '../../../AnalysisToolbox/gitatbx/modules/analyzers/relative_analyzer.py'
params.referencing_processor_script     = '../../../AnalysisToolbox/gitatbx/modules/processors/referencing_processor.py'
params.log_transform_script             = '../../../AnalysisToolbox/gitatbx/modules/processors/log_transform_processor.py'
params.tddr_processor_script            = '../../../AnalysisToolbox/gitatbx/modules/processors/tddr_processor.py'
params.linear_transform_script          = '../../../AnalysisToolbox/gitatbx/modules/processors/linear_transform_processor.py'
params.regression_processor_script      = '../../../AnalysisToolbox/gitatbx/modules/processors/regression_processor.py'
params.ic_analyzer_script               = '../../../AnalysisToolbox/gitatbx/modules/analyzers/ic_analyzer.py'
params.quest_analyzer_script            = '../../../AnalysisToolbox/gitatbx/modules/analyzers/quest_analyzer.py'
params.amplitude_analyzer_script        = '../../../AnalysisToolbox/gitatbx/modules/analyzers/amplitude_analyzer.py'
params.interval_analyzer_script         = '../../../AnalysisToolbox/gitatbx/modules/analyzers/interval_analyzer.py'
params.psd_analyzer_script              = '../../../AnalysisToolbox/gitatbx/modules/analyzers/psd_analyzer.py'
params.asymmetry_analyzer_script        = '../../../AnalysisToolbox/gitatbx/modules/analyzers/asymmetry_analyzer.py'
params.group_analyzer_script            = '../../../AnalysisToolbox/gitatbx/modules/analyzers/group_analyzer.py'
params.bootstrap_analyzer_script        = '../../../AnalysisToolbox/gitatbx/modules/analyzers/bootstrap_analyzer.py'
params.merging_processor_script         = '../../../AnalysisToolbox/gitatbx/modules/processors/merging_processor.py'
params.interactive_plotter_script       = '../../../AnalysisToolbox/gitatbx/bin/interactive_plotter.py'
params.result_collector_script          = '../../../AnalysisToolbox/gitatbx/utils/result_collector.py'
params.toolbox_dir                      = '../../../AnalysisToolbox/gitatbx'
params.lgcrct_loso_script               = '../common/lgcrct_loso_adapter.py'

// Extraction
params.extraction_columns = 'EDA EKG triggerStream 9:-1'

// Tree markers
params.depth_delim        = 'Level'
params.kv_delim           = ':'
params.entry_delim        = '\\n'

// Filtering
params.eda_l_freq         = 0.05
params.eda_h_freq         = 5.0
params.ecg_l_freq         = 0.5
params.ecg_h_freq         = 40.0
params.eeg_l_freq         = 1.0
params.eeg_h_freq         = 40.0
params.sfreq              = 1000
params.ftype              = 'bandpass'
params.fnirs_l_freq       = 0.01
params.fnirs_h_freq       = 0.1
params.fnirs_sfreq        = 7.81
params.fnirs_ppf          = 6.0
params.fnirs_baseline_sec = 5.0
// NIRx 8x8 long-channel pairs for MBLL: 17 SD pairs (D1-D7 only, excluding short D8-D15)
// interleaved as (wl=0, wl=1) pairs so the 2×2 MBLL matrix is applied to the correct wavelengths.
// Layout in _regr.fif: positions 1-25 = wl=0, positions 26-50 = wl=1 (same SD order, offset +25).
// Each pair: wl=0 channel (760 nm) followed immediately by its wl=1 channel (850 nm).
params.fnirs_channels     = '1,26,2,27,4,29,5,30,7,32,8,33,10,35,11,36,13,38,14,39,16,41,17,42,19,44,20,45,22,47,23,48,24,49'
params.ecg_channel        = 'EKG'
params.eda_channel        = 'EDA'

// Epoching
params.conds              = "['POS*', 'NEG*', 'NEU*']"
params.eeg_reference      = 'average'
// EEG channels to exclude before ICA:
//   Fp1/Fp2       = frontopolar, dominated by eye artifacts
//   TP9/TP10      = mastoid edge, jaw/ear muscle noise
//   fNIRS sources  (no EEG electrode): S1(AFp1) S2(AFF1h) S3(AFp2) S4(AFF2h)
//                                      S5(P1) S6(PO3) S7(PPO6h) S8(PPO2h)
//   fNIRS detectors (no EEG electrode): D1(AF3) D2(AFz) D3(AF4)
//                                       D4(P2) D5(PO4) D6(PPO1h) D7(PPO5h)
params.eeg_ica_exclude    = '["Fp1","Fp2","TP9","TP10","AFp1","AFF1h","AFp2","AFF2h","P1","PO3","PPO6h","PPO2h","AF3","AFz","AF4","P2","PO4","PPO1h","PPO5h"]'
params.eeg_ica_interpolate = '["F3","F4"]'

// Analysis/Questionnaires
params.panas_param        = "[{'x-labels': ('panasList', 'panas'), 'y-labels': ['gar nicht', 'ein bisschen', 'einigermaßen', 'erheblich', 'äußerst'], 'data': 'panas.Choice1.Value'}]"
params.bisbas_param       = "[{'x-labels': ('bisBasList', ['Familie', 'Nervosität', 'Anstrengung', 'Ausdauer', 'Neugier', 'Kleidung', 'Energie', 'Kritikempf.', 'Zielstrebig', 'Spaßsuche', 'Zeitmanagem.', 'Chancen', 'Sorge', 'Spannung', 'Impulsiv', 'Unruhe', 'Verhalten', 'Berührbar', 'Fehlersorge', 'Abwechslung', 'Hartnäckig', 'Angstfrei', 'Wettbewerb', 'Fehlerangst']), 'y-labels': ['gar nicht', 'eher nicht', 'eher', 'genau'], 'data': 'bisBas.Choice1.Value'}]"
params.sam_param          = "['POS*', 'NEG*', 'NEU*', {'x-labels': ('samList', ['Valence', 'Arousal']), 'y-max': 9, 'y-labels': ['1', '2', '3', '4', '5', '6', '7', '8', '9'], 'data': 'SAM.Choice1.Value'}]"
params.be7_param          = "['POS*', 'NEG*', 'NEU*', {'x-labels': ('be7List', 'emotion'), 'y-labels': ['gar nicht', 'extrem'], 'y-max': 5, 'data': 'be7.Choice1.Value'}]"
params.ea11_param         = "['POS*', 'NEG*', 'NEU*', {'x-labels': ('ea11List', 'adjective'), 'y-labels': ['gar nicht', 'extrem'], 'y-max': 5, 'data': 'ea11.Choice1.Value'}]"

// Analysis/Physiology
params.bands_config       = "{'alpha': (8, 13), 'beta': (13, 30), 'theta': (4, 8)}"
// EEG ROI definitions for PSD analysis (frontal and parietal regions, standard 10-20 labels)
params.eeg_rois            = '{"Frontal": ["Fz", "F3", "F4", "F7", "F8"], "Parietal": ["Pz", "P3", "P4", "P7", "P8"]}'
// Band column names for outlier rejection (must match keys in bands_config)
params.eeg_band_list       = "['alpha','beta','theta']"
// Epoch-level band power outlier threshold (z-score); epochs beyond this many SDs from the mean are removed
params.psd_outlier_threshold = 3.0
// Within-participant pairwise contrasts for EEG PSD stats (condition labels must match epoch data)
params.eeg_psd_contrasts     = "{'POS-NEU': {'POS': 1, 'NEU': -1}, 'NEG-NEU': {'NEG': 1, 'NEU': -1}, 'POS-NEG': {'POS': 1, 'NEG': -1}}"
params.fai_band_name      = 'alpha'
params.electrode_pairs    = "[('F3', 'F4')]"
// fNIRS ROI definitions using NIRx channel patterns (source-detector:index-wavelength format)
// Montage: S1(AFp1), S2(AFF1h), S3(AFp2), S4(AFF2h) = Frontal
//          S5(P1), S6(PO3), S7(PPO6h), S8(PPO2h)    = Parietal
//          D8 = short channel detector (excluded by short_channel_processor)
// Left PFC: S1,S2 | Right PFC: S3,S4 | Left Parietal: S5,S6 | Right Parietal: S7,S8
// Including parietal ROIs improves global average quality by covering more cortical area
params.fnirs_rois         = '{"Left PFC": ["re:^[12]-"], "Right PFC": ["re:^[34]-"]}'
params.fnirs_epoch_baseline_sec = 5.0
params.fnirs_chromophores = '{\"HbO\": \":0\$\", \"HbR\": \":1\$\"}'
// Visualization label map: keys are matched case-insensitively against underscore-split
// parts of column names; values are the human-readable replacements.
// e.g. "eeg_Frontal_alpha" → "EEG Frontal α"
params.vis_label_map      = '{"eeg": "EEG", "eda": "EDA", "hrv": "HRV", "ecg": "ECG", "emg": "EMG", "fnirs": "fNIRS", "alpha": "α", "beta": "β", "theta": "θ", "delta": "δ", "gamma": "γ"}'

// Plotter parameters (questionnaires)
params.panas_plot_prefix  = 'panas'
params.bisbas_plot_prefix = 'bisbas'
params.sam_plot_prefix    = 'sam'
params.be7_plot_prefix    = 'be7'
params.ea11_plot_prefix   = 'ea11'

// Plotter parameters (physiological)
params.hrv_plot_prefix    = 'hrv'
params.eda_plot_prefix    = 'eda'
params.psd_plot_prefix    = 'psd'
params.fai_plot_prefix    = 'fai'

// Y-axis limits for physiological plots (ensures consistent scaling across participants)
params.hrv_y_lim          = 1.2
params.hrv_metrics_mode   = 'auto'  // 'auto' = both (SDNN+RMSSD), or specify single: 'SDNN', 'RMSSD'
params.eda_y_lim          = 0.5
params.psd_y_lim          = 15.0
params.fai_y_lim          = 0.4
params.fnirs_y_lim        = 0.5

// Bootstrap parameters for group-level statistics
params.bootstrap_n_boot   = 10000
params.bootstrap_ci_method = 'percentile'  // 'percentile', 'bca', 'normal'
params.bootstrap_alpha    = 0.05  // 0.05 for 95% CI

// Bootstrap windowing parameters (sliding windows within epochs for higher sample size)
params.bootstrap_window_size = 30.0  // Window duration in seconds
params.bootstrap_step_size   = 10.0  // Step size in seconds (overlap = window_size - step_size)
                                      // Example: 180s trial with 30s windows, 10s step → ~16 windows per trial

// Artifact rejection thresholds
params.eda_rejection_threshold = 100.0  // Amplitude threshold for EDA artifact removal (μS)
params.ecg_rejection_threshold = 5000.0  // Amplitude threshold for ECG artifact removal (µV — ECG is extracted from EEG stream)

// Exploratory LGC-RCT branch (cross-subject LOSO).
// Install once in the Linux venv used by Nextflow:
//   /home/gutt/EV_venv/bin/pip install lgc-rct
params.enable_lgcrct_branch = false
params.lgcrct_mode          = 'pilot'
params.lgcrct_targets       = 'condition'
params.lgcrct_band          = '15,36'
params.lgcrct_window_sec    = 4
params.lgcrct_step_sec      = 2
params.lgcrct_threshold     = 5.0
params.lgcrct_use_lgc       = true
params.lgcrct_half_window   = 10
params.lgcrct_cov_estimator = 'lwf'
params.lgcrct_lgc_mean      = 'riemann'
