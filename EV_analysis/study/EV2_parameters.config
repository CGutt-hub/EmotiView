// EV2 Secondary Analysis — Pipeline Parameters

// Reference generic toolbox config (labels, executor settings, etc.)
includeConfig '../../../AnalysisToolbox/gitatbx/bin/nextflow.config'

// Git commit author configuration
params.git_user_name  = 'EV2 Pipeline'
params.git_user_email = 'ev2-pipeline@automated.local'

// ── Input / Output ─────────────────────────────────────────────────────────
// Kaggle dataset is downloaded automatically at pipeline start via deap_bootstrap.py.
// To use a local copy instead, point params.kaggle_config to a parquet containing
// {kaggle_id: "manh123df/EV2-dataset"} and ensure kagglehub is installed.
params.output_dir     = '../../EV_results/study'
params.project_name   = 'EV2'
params.l2_analyses    = true
params.l2_folder      = 'EV2_l2'

// Pipeline trace
trace {
    enabled = true
    file    = "../../EV_results/study/.bin/pipeline_trace.txt"
}

// ── Python environment ─────────────────────────────────────────────────────
params.python_exe  = '/home/gutt/EV_venv/bin/python3'
params.venv_path   = '/home/gutt/EV_venv'

// ── Script paths ───────────────────────────────────────────────────────────
// EV2-specific
params.ev2_bootstrap_script        = 'EV2_bootstrap.py'
params.ev2_ingestor_script         = 'EV2_ingestor.py'
params.study_l2_analysis_script    = 'EV2_l2_analysis.py'
params.ev2_fai_label_export_script = 'EV2_fai_label_export.py'
params.lgcrct_loso_script          = '../common/lgcrct_loso_adapter.py'
params.kaggle_config                = 'kaggle_config.parquet'
params.result_collector_script      = '../../../AnalysisToolbox/gitatbx/utils/result_collector.py'
params.plv_analyzer_script          = '../../../AnalysisToolbox/gitatbx/modules/analyzers/plv_analyzer.py'

// Shared toolbox scripts (identical to EV_parameters.config)
params.file_finder_script           = '../../../AnalysisToolbox/gitatbx/modules/utils/file_finder.py'
params.peak_detection_processor_script = '../../../AnalysisToolbox/gitatbx/modules/processors/peak_detection_processor.py'
params.phase_analyzer_script        = '../../../AnalysisToolbox/gitatbx/modules/analyzers/phase_analyzer.py'
params.asymmetry_analyzer_script    = '../../../AnalysisToolbox/gitatbx/modules/analyzers/asymmetry_analyzer.py'
params.amplitude_analyzer_script    = '../../../AnalysisToolbox/gitatbx/modules/analyzers/amplitude_analyzer.py'
params.interval_analyzer_script     = '../../../AnalysisToolbox/gitatbx/modules/analyzers/interval_analyzer.py'
params.correlation_analyzer_script  = '../../../AnalysisToolbox/gitatbx/modules/analyzers/correlation_analyzer.py'
params.toolbox_dir                  = '../../../AnalysisToolbox/gitatbx'

// ── EV2 signal parameters ─────────────────────────────────────────────────
params.ev2_sfreq         = 128          // Hz — EV2 is downsampled to 128 Hz

// ── EEG parameters ────────────────────────────────────────────────────────
// FAI: frontal alpha asymmetry (F3 vs F4, alpha band 8–13 Hz)
params.fai_electrode_pairs = "[('F3','F4')]"
params.fai_band_name       = 'alpha'

// EEG PSD descriptive: channels to include (None = all 32)
params.eeg_psd_channels    = 'None'
params.eeg_max_freq        = 45

// ── Visualisation parameters (required by workflow_wrapper.nf) ─────────────
params.interactive_plotter_script = '../../../AnalysisToolbox/gitatbx/bin/interactive_plotter.py'
params.vis_label_map = '{"eeg": "EEG", "eda": "EDA", "hrv": "HRV", "bvp": "BVP", "alpha": "α", "beta": "β", "theta": "θ", "fai": "FAI", "plv": "PLV"}'

// ── Exploratory LGC-RCT branch (cross-subject LOSO) ────────────────────────
// Install once in the Linux venv used by Nextflow:
//   /home/gutt/EV_venv/bin/pip install lgc-rct
params.enable_lgcrct_branch = false
params.lgcrct_mode          = 'study'
params.lgcrct_targets       = 'valence,arousal'
params.lgcrct_band          = '15,36'
params.lgcrct_window_sec    = 4
params.lgcrct_step_sec      = 2
params.lgcrct_threshold     = 5.0
params.lgcrct_use_lgc       = true
params.lgcrct_half_window   = 10
params.lgcrct_cov_estimator = 'lwf'
params.lgcrct_lgc_mean      = 'riemann'
