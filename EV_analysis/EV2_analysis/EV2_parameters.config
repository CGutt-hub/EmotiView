// =========================================================================
// EV2 Secondary Analysis — Pipeline Parameters & Toolset Sync
// =========================================================================

// Referenz auf die generische Toolbox-Konfiguration (Labels, Executor-Settings, etc.)
includeConfig '../../../AnalysisToolbox/gitatbx/.bin/utils/nextflow.config'

// Git-Commit Autorendaten für automatisiertes Tracking
params.git_user_name  = 'EV2 Pipeline'
params.git_user_email = 'ev2-pipeline@automated.local'

// ── Input / Output Verzeichnisse ──────────────────────────────────────────
// Das Kaggle-Dataset wird beim Start automatisch via deap_bootstrap.py geladen.
// Teilnehmer sind als EV2_01 .. EV2_32 benannt (Umsortierung von DEAP s01..s32).
params.input_dir           = 'EV2_dataset'
params.output_dir          = '../../EV_results/EV2_results'
params.project_name        = 'EV2'
params.l2_analyses         = true
params.l2_folder           = 'EV2_l2'
params.participant_pattern = 'EV2_*'  // Regex für Probanden-Ordner
params.watch               = false    // Watch-Mode für dynamisch eintreffende Daten

// Pipeline Trace für das Laufzeit-Monitoring
trace {
    enabled = true
    file    = "../../EV_results/EV2_results/.bin/pipeline_trace.txt"
}

// ── Python-Laufzeitumgebung ────────────────────────────────────────────────
params.python_exe          = '/home/gutt/EV_venv/bin/python3'
params.venv_path           = '/home/gutt/EV_venv'

// ── Synchronisierte Skript-Pfade (Exakt gemappt auf EV2_pipeline.nf) ───────
// EV2-spezifisches Daten-Staging & Vorbereitung
params.ev2_dataset_setup_script    = '../../../AnalysisToolbox/gitatbx/modules/utils/kaggle_downloader.py'
params.ev2_label_binner_script      = '../../../AnalysisToolbox/gitatbx/modules/processors/label_binner.py'
params.bootstrap_analyzer_script    = '../../../AnalysisToolbox/gitatbx/modules/analyzers/bootstrap_analyzer.py'

// Wissenschaftliche Core-Extraktoren (Step 3)
params.spectrum_analyzer_script     = '../../../AnalysisToolbox/gitatbx/modules/analyzers/spectrum_analyzer.py'
params.asymmetry_analyzer_script    = '../../../AnalysisToolbox/gitatbx/modules/analyzers/asymmetry_analyzer.py'
params.amplitude_analyzer_script    = '../../../AnalysisToolbox/gitatbx/modules/analyzers/amplitude_analyzer.py'
params.interval_analyzer_script     = '../../../AnalysisToolbox/gitatbx/modules/analyzers/interval_analyzer.py'
params.psd_analyzer_script          = '../../../AnalysisToolbox/gitatbx/modules/analyzers/psd_analyzer.py'

// Statistische Rechenknoten (Level 1 & Level 2)
params.anova_analyzer_script        = '../../../AnalysisToolbox/gitatbx/modules/analyzers/anova_analyzer.py'
params.correl_analyzer_script       = '../../../AnalysisToolbox/gitatbx/modules/analyzers/correl_analyzer.py'
params.correlation_analyzer_script  = '../../../AnalysisToolbox/gitatbx/modules/analyzers/correl_analyzer.py' // Fallback-Alias
params.ols_processor_script         = '../../../AnalysisToolbox/gitatbx/modules/processors/ols_processor.py'
params.lmm_analyzer_script          = '../../../AnalysisToolbox/gitatbx/modules/analyzers/lmm_analyzer.py'

// WP5: Multimodaler Machine Learning Classifier (LOSO)
params.multimodal_classifier_script = '../../../AnalysisToolbox/gitatbx/modules/analyzers/multimodal_classifier.py'

// Infrastruktur-Skripte für Joiner und Concatenator
params.join_processor_script          = '../../../AnalysisToolbox/gitatbx/modules/processors/join_processor.py'
params.concatenating_processor_script = '../../../AnalysisToolbox/gitatbx/modules/processors/concatenating_processor.py'

// Legacy / Hilfs-Prozessoren der Toolbox
params.l2_anova_consolidator_script   = '../../../AnalysisToolbox/gitatbx/modules/analyzers/anova_analyzer.py'
params.l2_lmm_consolidator_script     = '../../../AnalysisToolbox/gitatbx/modules/analyzers/lmm_analyzer.py'
params.sam_l2_lmm_consolidator_script = '../../../AnalysisToolbox/gitatbx/modules/analyzers/lmm_analyzer.py'
params.result_collector_script        = '../../../AnalysisToolbox/gitatbx/utils/result_collector.py'
params.row_filter_processor_script    = '../../../AnalysisToolbox/gitatbx/modules/processors/row_filter_processor.py'
params.contrast_processor_script      = '../../../AnalysisToolbox/gitatbx/modules/processors/contrast_processor.py'
params.peak_detection_processor_script = '../../../AnalysisToolbox/gitatbx/modules/processors/peak_detection_processor.py'
params.pivot_processor_script         = '../../../AnalysisToolbox/gitatbx/modules/processors/pivot_processor.py'
params.epoching_processor_script      = '../../../AnalysisToolbox/gitatbx/modules/processors/epoching_processor.py'
params.trial_aggregator_script         = '../../../AnalysisToolbox/gitatbx/modules/processors/trial_aggregator.py'
params.toolbox_dir                    = '../../../AnalysisToolbox/gitatbx'

// Mapping-Konfigurationen für Konsolidierungen
params.l2_anova_modality_map        = '{"eda":["eda"],"hrv":["hrv"],"fai":["fai"],"eeg_frontal":["eeg_frontal"],"eeg_parietal":["eeg_parietal"]}'
params.eda_amplitude_pattern        = '*amp*.parquet pass'

// ── EV2 Signal-Parameter ──────────────────────────────────────────────────
params.ev2_sfreq           = 128        // Hz — DEAP-Daten sind auf 128 Hz downsampled

// ── Per-Condition Bootstrap & Split Parameter ─────────────────────────────
// Schwellenwerte für den Median-Split der DEAP-Trials in High/Low Valence & Arousal.
params.ev2_valence_threshold  = 5
params.ev2_arousal_threshold  = 5
params.ev2_neutral_band       = 1.0     // Halbe Breite der neutralen Zone um den Schwellenwert (0 = rein binär)

// Pairwise Contrasts für EEG OLS: Kern-theoretische Vergleiche (High vs Low pro Dimension)
params.eeg_bin_contrasts      = "{'aH-aL': {'arousal_high': 1, 'arousal_low': -1}, 'vH-vL': {'valence_high': 1, 'valence_low': -1}}"

// Bootstrap Einstellungen für per-participant Profile (EV1-Äquivalenz)
params.bootstrap_n_boot       = 10000
params.bootstrap_ci_method    = 'percentile'
params.bootstrap_alpha        = 0.05

// ── EEG Parameter & ROI Definitionen ──────────────────────────────────────
// FAI: Frontal Alpha Asymmetry (F3 vs F4, Alpha-Band 8–13 Hz)
params.fai_electrode_pairs = "[('F3','F4')]"
params.fai_band_name       = 'alpha'
params.fai_column          = 'fai_F3_F4'

// EEG PSD deskriptiv (None = alle 32 ch nutzen)
params.eeg_psd_channels    = 'None'
params.eeg_max_freq        = 45         // BEHOBEN: Doppelter Eintrag gelöscht, auf Zielwert 45Hz gesetzt

// ROI Channel-Sets für Frontal und Parietal (DEAP 32-Kanal Layout)
params.eeg_rois            = '{"Frontal": ["Fz", "F3", "F4", "F7", "F8"], "Parietal": ["Pz", "P3", "P4", "P7", "P8"]}'

// Sliding-Window Parameter zur Erhöhung der ANOVA Freiheitsgrade
params.eeg_window_size     = 30.0       // Fensterlänge in Sekunden
params.eeg_step_size       = 10.0       // Schrittweite in Sekunden (Überlappung = 20s)

// Banddefinitionen für den Regionen-Modus des psd_analyzers
params.bands_config        = "{'alpha':, 'beta':, 'theta': [4, 8]}"
params.psd_y_lim           = 'None'     // y-Achsen Limit für Plots (None = Auto)

// ── Visualisierungs-Parameter (Für workflow_wrapper.nf) ───────────────────
params.interactive_plotter_script = '../../../AnalysisToolbox/gitatbx/bin/interactive_plotter.py'
params.vis_label_map = '{"eeg": "EEG", "eda": "EDA", "hrv": "HRV", "bvp": "BVP", "alpha": "α", "beta": "β", "theta": "θ", "fai": "FAI", "plv": "PLV"}'